{
  "name": "imagetabs",
  "version": "1.1.0",
  "manifest_version": 2,
  "permissions": [
    "tabs",
    "activeTab",
    "history",
    "<all_urls>",
    "storage"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_icon": "16x16.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "imagetabs@example.com",
      "strict_min_version": "142.0",
      "update_url": "https://raw.githubusercontent.com/softmix/imagetabs/master/updates.json",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
